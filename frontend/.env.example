# Public anon key - safe to expose in the built frontend.
# RLS on Supabase only allows SELECT on pokemon_daily_forecast for this key.
VITE_SUPABASE_URL=https://xxxxxxxx.supabase.co
VITE_SUPABASE_ANON_KEY=

# Set to "true" to bypass Supabase and render the calendar with generated
# sample data - useful for local UI development before the backend/DB exists.
VITE_USE_MOCK_DATA=false

