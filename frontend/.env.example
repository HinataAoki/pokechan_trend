# Public URL of the baked JSON snapshot (Supabase Storage public bucket),
# generated by backend/export_snapshot.py. No Supabase client/keys needed -
# the frontend just fetches this one static file.
VITE_SNAPSHOT_URL=https://xxxxxxxx.supabase.co/storage/v1/object/public/public-data/snapshot.json

# Set to "true" to bypass the snapshot fetch and render the calendar with
# generated sample data - useful for local UI development before the
# backend/DB exists.
VITE_USE_MOCK_DATA=false

# Google Analytics (GA4) measurement id, e.g. G-XXXXXXXXXX.
# Leave empty to disable analytics entirely (nothing is loaded).
VITE_GA_MEASUREMENT_ID=
